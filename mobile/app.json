{
  "expo": {
    "name": "floq",
    "slug": "floq",
    "version": "1.0.0",
    "scheme": "floq",
    "orientation": "portrait",
    "icon": "./assets/icon-light.png",
    "userInterfaceStyle": "automatic",
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0F0F0F",
          "image": "./assets/splash-oq.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#0F0F0F",
            "image": "./assets/splash-oq.png"
          }
        }
      ],
      "react-native-fast-tflite",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.1058460931992-t3baiop5eu0lo2vbklam62papl6v1ooa"
        }
      ],
      "expo-router",
      "expo-font",
      "expo-sqlite"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.floq.app",
      "icon": {
        "light": "./assets/icon-light.png",
        "dark": "./assets/icon-dark.png"
      }
    },
    "android": {
      "predictiveBackGestureEnabled": false
    }
  }
}
