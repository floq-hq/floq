# Firebase web-app config for floq-prod (M1.4).
#
# Copy this file to `mobile/.env` and fill in the blanks from:
#   Firebase console -> Project settings -> Your apps -> Web app
#   -> SDK setup and configuration -> "Config"
#
# These values ship to the client and are NOT secret, but they live in .env so
# they aren't hard-coded per environment. `.env` is gitignored; this example is
# tracked. Also store a copy in the shared 1Password vault.
#
# The EXPO_PUBLIC_ prefix is required — Expo only inlines those into the bundle.

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=floq-prod.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=floq-prod
# Copy the exact value from the console — newer projects use
# floq-prod.firebasestorage.app instead of floq-prod.appspot.com.
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# --- LLM task parser (M2.3 / decisions.md L10 + L12) ---
#
# Client-direct for beta (L12): these keys are inlined into the JS bundle and
# are extractable. Treat them as rotatable; monitor usage.
#
# PRIMARY — Gemini (best quality; key IS restrictable). Get it from Google AI
# Studio (aistudio.google.com) -> "Get API key", then in Google Cloud restrict
# it to the iOS bundle id `com.floq.app` + the Generative Language API only.
EXPO_PUBLIC_GEMINI_API_KEY=
#
# FALLBACK — Groq llama-3.1-8b-instant (14,400 RPD; absorbs overflow once Gemini
# hits its 1,000/day). NOTE: Groq has no bundle-id restriction, so this key is
# fully unrestricted if leaked — rotatable mitigation only. Get it from
# console.groq.com -> API Keys.
EXPO_PUBLIC_GROQ_API_KEY=
#
# OPTIONAL third link — leave blank unless needed (chain skips unconfigured).
# EXPO_PUBLIC_OPENROUTER_API_KEY=
