rules_version = '2';

// Floq Firestore security rules.
//
// M1.4 — INITIAL LOCKDOWN. Deny all client access. The real per-collection
// rules (owner-only on users/{uid}, friends-readable social docs, etc.) are
// opened deliberately as each feature lands:
//   - owner-only read/write on users/{uid} + subcollections  -> M2.2
//   - friendships / friend_requests / friends-readable social -> M7.1
//
// SAFETY (per CLAUDE.md): changes here must be backward-compatible and
// reviewed. LOOSENING any rule (making something readable/writable that wasn't)
// requires explicit sign-off. Follow the access principles in the
// `floq-firestore` skill when opening these up.
service cloud.firestore {
  match /databases/{database}/documents {

    // M2.2 — owner-only on the user document and all owned subcollections.
    // A user reads/writes only their own users/{uid} tree; nobody else can.
    // TODO(M7.1): add a friends-readable exception for the social profile doc.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Everything else stays denied until its feature lands.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
